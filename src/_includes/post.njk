---
layout: base.njk
---
<article class="post">
  <header class="post-header">
    <h1>{{ issue.title }}</h1>
    <time datetime="{{ issue.date | isoDate }}">{{ issue.date | humanDate }}</time>
  </header>
  {% if issue.image %}<img class="post-cover" src="{{ issue.image }}" alt="" loading="lazy">{% endif %}
  <div class="post-body">
    {{ issue.bodyHtml | safe }}
  </div>
  <footer class="post-footer">
    <p>Originally published on <a href="{{ issue.sourceUrl }}" rel="canonical">LinkedIn</a>.</p>
    <p><a href="/">← All issues</a></p>
  </footer>
</article>
